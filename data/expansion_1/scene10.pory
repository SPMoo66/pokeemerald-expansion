	applymovement (MAUVECAMP_JAKSON, Common_Movement_QuestionMark)
	delay (40)
	speakername (CommonText_Jakson)
	msgbox ("You saw something?\p"
			"… {PAUSE 30}… {PAUSE 30}…\p"
			"If you really think so…\p"
			"NPCs should be pretty static now,\n"
			"so…\l"
			"Well… {PAUSE 100} Hmmm…\p"
			"… {PAUSE 30}… {PAUSE 30}… {PAUSE 30}\n"
			"… {PAUSE 30}… {PAUSE 30}…\l"
			"Let me know if you see anything else.\p"
			"…{PAUSE 100}Why?\p"
			"I… {PAUSE 100}I've got a running theory on why\n"
			"some of the bugs we saw happened.\p"
			"Don't worry, it's not anything serious.\n"
			"Or… {PAUSE 100}even likely.\l"
			"Probably…", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkRight2)
	waitmovement (0)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkDown5)
