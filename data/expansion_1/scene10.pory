	fadescreen (FADE_TO_BLACK)

	removeobject (MAUVECAMP_BARON)
	removeobject (MAUVECAMP_HARPER)
	removeobject (MAUVECAMP_SAKURA)
	removeobject (MAUVECAMP_JAKSON)
