script BattleWarningLavaridgeSakuraHelper {
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	if (var(VAR_TEMP_0) == 12 && var(VAR_TEMP_1) == 12) {
		call (BattleWarningLavaridgeSakura)
	}
	else {
		setvar (VAR_TEMP_6, 1)
	}
}

