	waitmovement (0)
	fadenewbgm (MUS_B_PIKE)
	delay (80)
	applymovement (LOCALID_PLAYER, Common_Movement_QuestionMark)
	delay (80)
	applymovement (LOCALID_PLAYER, Common_Movement_WalkInPlaceFasterUp)
