const IG_BOSS = 3
const IG_HARPER = 4
const IG_JAKSON = 5
const IG_REDD = 6
const IG_BARON = 7
const IG_SAKURA = 8
const IG_SHADOWED_LUCARIO_1 = 9
const IG_SHADOWED_LUCARIO_2 = 10
const MAUVECAMP_JAKSON = 6
const MAUVECAMP_BARON = 7
const MAUVECAMP_SAKURA = 8
const MAUVECAMP_FAKEPLAYER = 9
const MAUVECAMP_REDD = 10
const MAUVECAMP_HARPER = 11
const MAUVECAMP_SHADOW_BARON = 12

script IGB4_MoveCameraUp {
	if (var(VAR_EMERALBODY_RIVAL_STATE) == 50) {
		setvar (VAR_TEMP_2, 1)
		special (SpawnCameraObject)
		applymovement (LOCALID_CAMERA, Common_Movement_WalkUp2)
		waitmovement (0)
		special (RemoveCameraObject)
	}
	else {
		setvar(VAR_TEMP_2, 2)
	}
}

script IGB4_MoveCameraDown {
	special (SpawnCameraObject)
	applymovement (LOCALID_CAMERA, Common_Movement_WalkDown2)
	waitmovement (0)
	special (RemoveCameraObject)
	setvar (VAR_TEMP_2, 0)
}


script Expansion1_Rival_Scene10 {
	msgbox ("Are you prepared to face off\n"
			"against your final opponents?", MSGBOX_YESNO)
	closemessage
	if (var(VAR_RESULT) == YES) {
		goto (Expansion1_Rival_Scene10b)
	}
	else {
		applymovement (LOCALID_PLAYER, Common_Movement_WalkDown)
		waitmovement (0)
	}
}

script Expansion1_Rival_Scene10b {
	applymovement (IG_HARPER, Common_Movement_WalkInPlaceFasterDown)
	waitmovement (0)
	speakername (CommonText_Harper)
	msgbox ("{PLAYER}!\n"
			"It looks like it worked in the end!\l"
			"Let's take this on together.", MSGBOX_AUTOCLOSE)
	getplayerxy (VAR_TEMP_0, VAR_TEMP_1)
	switch (var(VAR_TEMP_0)) {
		case 23:
			applymovement (LOCALID_PLAYER, Common_Movement_WalkRight2)
		case 24:
			applymovement (LOCALID_PLAYER, Common_Movement_WalkRight)
		case 26:
			applymovement (LOCALID_PLAYER, Common_Movement_WalkLeft)
		case 27:
			applymovement (LOCALID_PLAYER, Common_Movement_WalkLeft2)
		case 28:
			applymovement (LOCALID_PLAYER, Common_Movement_WalkLeft3)
		case 29:
			applymovement (LOCALID_PLAYER, Common_Movement_WalkLeft4)
	}
	waitmovement (0)
	special (SpawnCameraObject)
	applymovement (IG_HARPER, Common_Movement_WalkInPlaceFasterUp)
	applymovement (LOCALID_CAMERA, Common_Movement_WalkDiagNE)
	applymovement (LOCALID_PLAYER, Common_Movement_WalkUp2)
	waitmovement (0)
	playbgm (MUS_DP_CATASTROPHE, FALSE)
	speakername (CommonText_Jakson)
	msgbox ("Everyone, get ready! This'll be custom,\n"
			"so there's no telling how it will go!")
	speakername (CommonText_Redd)
	msgbox ("Hah… {PAUSE 100}with how everything else has\n"
			"gone? Custom mechanics sound like a\l"
			"perfectly chaotic climax.", MSGBOX_AUTOCLOSE)
	applymovement (IG_BARON, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	call (GetBaronsName)
	msgbox ("What?! {PAUSE 60}What do you mean ‘no telling’?!")
	speakername (CommonText_Sakura)
	msgbox ("Baron, we can take it! Back to back.\n"
			"Allies that fight until the final\l"
			"breath!", MSGBOX_AUTOCLOSE)
	applymovement (IG_BARON, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	playbgm (MUS_B2W2_VS_GHETSIS, TRUE)
	applymovement (IG_BOSS, Common_Movement_ShakeHorizontal)
	playmoncry (SPECIES_GYARADOS, CRY_MODE_ENCOUNTER)
	waitmoncry

# Battle Part 1
	setflag (FLAG_DONT_TRANSITION_BATTLE_MUSIC)
	setflag (FLAG_DONT_PLAY_VICTORY_MUSIC)
	setflag (FLAG_NO_MONEY_LOSS_ON_DEFEAT)
	setflag (FLAG_SINGLE_WILD_OPPONENT)
	setflag (FLAG_SYS_SET_BATTLE_TRANSITION)
	setvar (VAR_BATTLE_TRANSITION, 1)
	settotemboost (B_POSITION_OPPONENT_LEFT, 0, 1, 0, 0, 1)
	multi_2_vs_1 (TRAINER_EXP_1_FINAL_BATTLE_1, "Gyashaa!", PARTNER_FOLLOWER_HARPER_EXP_1_FINAL_BOSS)
	clearflag (FLAG_SINGLE_WILD_OPPONENT)
	clearflag (FLAG_DONT_TRANSITION_BATTLE_MUSIC)


	call (GetBaronsName)
	msgbox ("It-{PAUSE 30}It looks almost dead…{PAUSE 100}?\n"
			"Did we beat it?")
	speakername (CommonText_Harper)
	msgbox ("Tsk. This is when they're at their\n"
			"most dangerous.\p"
			"{EMOJI_BIGWHEEL}Clenches fist{EMOJI_BIGWHEEL}\n"
			"Down with you!", MSGBOX_AUTOCLOSE)
	
	playmoncry (SPECIES_GYARADOS, CRY_MODE_HIGH_PITCH)
	call (WeatherScript_SetAndDo_Rain)
	delay (60)

	playmoncry (SPECIES_LUCARIO, CRY_MODE_ENCOUNTER)
	waitmoncry
	addobject (IG_SHADOWED_LUCARIO_1)
	addobject (IG_SHADOWED_LUCARIO_2)
	playse (SE_PIN)
	applymovement (LOCALID_PLAYER, Common_Movement_ExclamationMark)
	applymovement (IG_HARPER, Common_Movement_ExclamationMark)
	applymovement (IG_SHADOWED_LUCARIO_1, Common_Movement_WalkUp)
	applymovement (IG_SHADOWED_LUCARIO_2, Common_Movement_WalkUp)
	waitmovement (0)
	playse (SE_LEDGE)
	applymovement (LOCALID_PLAYER, Common_Movement_WalkInPlaceFasterDown)
	applymovement (IG_HARPER, Common_Movement_WalkInPlaceFasterDown)
	applymovement (IG_SHADOWED_LUCARIO_1, Common_Movement_JumpUp)
	applymovement (IG_SHADOWED_LUCARIO_2, Common_Movement_JumpUp)
	waitmovement (0)
	applymovement (IG_SHADOWED_LUCARIO_1, Common_Movement_WalkUp2)
	applymovement (IG_SHADOWED_LUCARIO_2, Common_Movement_WalkUp2)
	waitmovement (0)

# Battle Part 2
	setflag (FLAG_NO_MONEY_LOSS_ON_DEFEAT)
	setflag (FLAG_WILD_OPPONENT)
	setflag (FLAG_SYS_SET_BATTLE_BGM)
	setflag (FLAG_SYS_CTRL_OBJ_DELETE)
	setvar (VAR_BATTLE_BGM, MUS_XD_VS_CIPHER_PEON)
	setflag (FLAG_DONT_PLAY_VICTORY_MUSIC)
	multi_2_vs_2 (TRAINER_WILD_POKEMON_IG_5, Exp1_WildPokemonTrainerText_Defeat, TRAINER_WILD_POKEMON_IG_6, Exp1_WildPokemonTrainerText_Defeat, PARTNER_FOLLOWER_HARPER_EXP_1_FINAL_BOSS)
	clearflag (FLAG_WILD_OPPONENT)
	clearflag (FLAG_SYS_CTRL_OBJ_DELETE)
	call (WeatherScript_SetAndDo_None)
	delay (30)


	applymovement (LOCALID_PLAYER, Common_Movement_WalkInPlaceFasterUp)
	applymovement (IG_HARPER, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("Again? Jeez! This guy won't give up!")
	speakername (CommonText_Sakura)
	msgbox ("HAHAHA!\n"
			"Live up to your name, {PAUSE 60}“Redd”!\l"
			"Let us BATHE IN THE BLOOD OF OUR\l"
			"ENEMIES!!!", MSGBOX_AUTOCLOSE)
	applymovement (IG_REDD, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("That's not-…{PAUSE 100}! F-{PAUSE 30}FINE!\n"
			"I can go another round!")
	speakername (CommonText_Jakson)
	msgbox ("Everything comes in threes.\n"
			"This should be the last phase!", MSGBOX_AUTOCLOSE)
	applymovement (IG_REDD, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Harper)
	msgbox ("One more time!")
	playmoncry (SPECIES_GYARADOS, CRY_MODE_ENCOUNTER)
	waitmoncry
	savebgm (MUS_NONE)

#Battle Part 3
	setstartingstatus (STARTING_STATUS_RAINBOW_PLAYER)
	setflag (FLAG_DONT_TRANSITION_BATTLE_MUSIC)
	setflag (FLAG_NO_MONEY_LOSS_ON_DEFEAT)
	setflag (FLAG_SINGLE_WILD_OPPONENT)
	setflag (FLAG_DONT_PLAY_VICTORY_MUSIC)
	settotemboost (B_POSITION_OPPONENT_LEFT, 0, 1, 0, 0, 1)
	setflag (FLAG_SYS_SET_BATTLE_BGM)
	setvar (VAR_BATTLE_BGM, MUS_B2W2_VS_GHETSIS)
	setflag (FLAG_SYS_SET_BATTLE_TRANSITION)
	setvar (VAR_BATTLE_TRANSITION, 1)
	multi_2_vs_1 (TRAINER_EXP_1_FINAL_BATTLE_2, "Gyassshaaa…", PARTNER_FOLLOWER_HARPER_EXP_1_FINAL_BOSS)
	clearflag (FLAG_SINGLE_WILD_OPPONENT)
	clearflag (FLAG_DONT_TRANSITION_BATTLE_MUSIC)

	setvar (VAR_0x8004, 2)  # vertical pan
	setvar (VAR_0x8005, 6)  # horizontal pan
	setvar (VAR_0x8006, 20)  # num shakes
	setvar (VAR_0x8007, 3)  # shake delay
	special (ShakeCamera)
	delay (50)
	playmoncry (SPECIES_GYARADOS, CRY_MODE_FAINT)
	mosaicmorph (IG_BOSS, OBJ_EVENT_GFX_NONE)
	delay (80)
	removeobject (IG_BOSS)

	speakername (CommonText_Redd)
	msgbox ("Is that…{PAUSE 60}?!")
	call (GetBaronsName)
	msgbox ("Did it… {PAUSE 100}Did it actually…{PAUSE 60}?", MSGBOX_AUTOCLOSE)
	applymovement (LOCALID_PLAYER, Common_Movement_Thinking)
	delay (80)
	playbgm (MUS_PL_VICTORY_FRONTIER_BRAIN, FALSE)
	speakername (CommonText_Harper)
	msgbox ("Whew… {PAUSE 100}Looks like that's finally it!")
	speakername (CommonText_Jakson)
	msgbox ("Yeah, I think we did it, guys!")
	call (GetBaronsName)
	msgbox ("I… {PAUSE 100}I did! I did it!")
	speakername (CommonText_Sakura)
	msgbox ("We {PAUSE 30}ALL {PAUSE 60}did it, Baron{EMOJI_TILDE}{UNK_SPACER}", MSGBOX_AUTOCLOSE)
	applymovement (IG_BARON, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	call (GetBaronsName)
	msgbox ("We all… {PAUSE 100}Baron…{PAUSE 60}?\p"
			"…{PAUSE 60}uh, yeah, haha…\p"
			"You can really lose where you are in\n"
			"some of those moments, can't you?")
	applymovement (IG_REDD, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("Mission accomplished?")
	call (GetBaronsName)
	msgbox ("That was… {PAUSE 100}blood pumping…{PAUSE 60}!")
	applymovement (IG_JAKSON, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("“Mission accomplished” seems right.\p"
			"Time for some fresh air?", MSGBOX_AUTOCLOSE)
	setflag (FLAG_HIDE_MAP_NAME_POPUP)
	setflag (FLAG_SCENE10_TRANSITION)
	fadescreen (FADE_TO_BLACK)
	warpcontinuescript (MAP_MAUVE_CAMP, 16, 8, Expansion1_Rival_Scene10c)
}

script Expansion1_Rival_Scene10c {
	setobjectxyperm (MAUVECAMP_JAKSON, 15, 10)
	setobjectmovementtype (MAUVECAMP_JAKSON, MOVEMENT_TYPE_FACE_UP)
	setobjectxyperm (MAUVECAMP_REDD, 17, 10)
	setobjectxyperm (MAUVECAMP_BARON, 17, 8)
	setobjectmovementtype (MAUVECAMP_BARON, MOVEMENT_TYPE_FACE_DOWN)
	setobjectxyperm (MAUVECAMP_HARPER, 16, 10)
	setobjectmovementtype (MAUVECAMP_HARPER, MOVEMENT_TYPE_FACE_UP)
	setobjectxyperm (MAUVECAMP_SAKURA, 15, 8)
	setobjectmovementtype (MAUVECAMP_SAKURA, MOVEMENT_TYPE_FACE_DOWN)
	addobject (MAUVECAMP_BARON)
	addobject (MAUVECAMP_HARPER)
	addobject (MAUVECAMP_SAKURA)
	addobject (MAUVECAMP_JAKSON)
	addobject (MAUVECAMP_REDD)
	fadescreen (FADE_FROM_BLACK)
	special (SpawnCameraObject)
	delay (40)
	applymovement (LOCALID_CAMERA, Common_Movement_WalkDown)
	waitmovement (0)
	delay (20)
	applymovement (MAUVEISLANDWEST_SAKURA, Common_Movement_MusicNote)
	playse (SE_RG_HELP_OPEN)
	delay (60)
	speakername (CommonText_Sakura)
	msgbox ("We did it!\p"
			"… {PAUSE 30}… {PAUSE 30}…\p"
			"Where's my treasure, Jakson?")
	speakername (CommonText_Redd)
	msgbox ("No one got any drops?")
	speakername (CommonText_Jakson)
	msgbox ("That's the question of the hour,\n"
			"isn't it?", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("What, so our gamemaster doesn't know\n"
			"either?")
	speakername (CommonText_Jakson)
	msgbox ("Well… {PAUSE 100}it's possible that there was never\n"
			"a real treasure, right?")
	speakername (CommonText_Sakura)
	msgbox ("So you set the stage for our grand\n"
			"treasure hunt without knowing if\l"
			"there was a treasure to be had?")
	call (GetBaronsName)
	msgbox ("Aww… {PAUSE 100}I was really looking forward to\n"
			"some healing items.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("Baron, you know that…", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_Thinking)
	delay (60)
	speakername (CommonText_Redd)
	msgbox ("Never mind.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_HARPER, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	speakername (CommonText_Harper)
	msgbox ("Jakson, you think the logic for the\n"
			"reward being dropped also got\l"
			"compromised?\p"
			"That would explain it, if true.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("We could look into the code behind this\n"
			"all to see if there was something there.\p"
			"But… {PAUSE 100}I guess it's hard to know if it\n"
			"was a weird bug or general messiness\l"
			"of the mod's creators…\l"
			"I…\l"
			"Argh…\l"
			"I can just spawn in a reward.")
	speakername (CommonText_Sakura)
	msgbox ("I sense a thief! The scallywags must've\n"
			"took our plunder for themselves.")
	speakername (CommonText_Redd)
	msgbox ("No, I'm pretty sure that's the end of\n"
			"the mod's story.")
	speakername (CommonText_Sakura)
	msgbox ("Darn. And if they're already gone it'll\n"
			"be too late for my Sakura Senses to\l"
			"pick them up.")
	call (GetBaronsName)
	msgbox ("{EMOJI_BIGWHEEL}Sigh{EMOJI_BIGWHEEL} {PAUSE 60}It's such an unfortunate\n"
			"limitation to the Sakura Senses.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("Jakson, I think she's asking for the\n"
			"reward to be spawned for each one of\l"
			"us.")
	speakername (CommonText_Jakson)
	msgbox ("{EMOJI_BIGWHEEL}Sigh{EMOJI_BIGWHEEL}…", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_HARPER, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Harper)
	msgbox ("…{PAUSE 100}Well, anyway. I agree that it seems\n"
			"like we've hit the ending.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("I can check again, but I believe we've\n"
			"concluded with that ‘main story’ part of\l"
			"this little expansion.")
	speakername (CommonText_Redd)
	msgbox ("Anything else? Do you think I could get\n"
			"one of those ‘Calamity Maw’ for myself?", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("I think so. Pretty sure that was the\n"
			"Paradox Pokémon naming scheme.\l"
			"And if not I'll make it so you can.")
	call (GetBaronsName)
	msgbox ("It certainly wasn't the only new…{PAUSE 100}\n"
			"Pokémon… {PAUSE 100}that I saw. I wonder…")
	speakername (CommonText_Sakura)
	msgbox ("Gotta prepare for the next expansion\n"
			"pack, right? Catch 'em all. All the cute\l"
			"and cool ones, at least.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("Yeah… {PAUSE 100}I'll keep working on that idea\n"
			"I had. And…\l"
			"And I'll not rush anything just because\l"
			"I'm taking forever myself.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_HARPER, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	speakername (CommonText_Harper)
	msgbox ("Pfft. Fine, I'll fix your gaffs.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_SweatDrop)
	playse (SE_M_METRONOME)
	delay (60)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("I… {PAUSE 100}didn't…")
	speakername (CommonText_Harper)
	msgbox ("So there were a couple of mods I saw\n"
			"online that…", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_HARPER, Common_Movement_Talking)
	delay (100)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_Talking)
	delay (80)
	applymovement (MAUVECAMP_BARON, Common_Movement_Thinking)
	delay (60)
	call (GetBaronsName)
	msgbox ("Was… {PAUSE 100}Harper always this into this\n"
			"topic?", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Redd)
	msgbox ("Maybe she just likes things feeling\n"
			"neat and tidy?")
	speakername (CommonText_Sakura)
	msgbox ("Or maybe those two are fucking?", MSGBOX_AUTOCLOSE)
	playse (SE_PIN)
	applymovement (MAUVECAMP_BARON, Common_Movement_ExclamationMark)
	delay (60)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterUp)
	applymovement (MAUVECAMP_HARPER, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("Sakura… {PAUSE 100}We're still here.")
	speakername (CommonText_Sakura)
	msgbox ("I mean platonically! Sheesh.")
	speakername (CommonText_Harper)
	msgbox ("I think I'll let people fill in the\n"
			"blanks however they want.", MSGBOX_AUTOCLOSE)
	playse (SE_PIN)
	applymovement (MAUVECAMP_BARON, Common_Movement_DoubleExclamationMark)
	applymovement (MAUVECAMP_REDD, Common_Movement_ExclamationMark)
	delay (60)
	speakername (CommonText_Sakura)
	msgbox ("Scandalous{EMOJI_TILDE}{UNK_SPACER}")
	applymovement (MAUVECAMP_BARON, Common_Movement_WalkInPlaceFasterLeft)
	waitmovement (0)
	call (GetBaronsName)
	msgbox ("Are they… {PAUSE 100}actually…{PAUSE 60}?", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_SweatDrop)
	playse (SE_M_METRONOME)
	delay (40)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterRight)
	waitmovement (0)
	speakername (CommonText_Jakson)
	msgbox ("Harper… {PAUSE 100}maybe don't imply something\n"
			"that isn't happening…{PAUSE 60}?", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_BARON, Common_Movement_WalkInPlaceFasterDown)
	waitmovement (0)
	speakername (CommonText_Harper)
	msgbox ("Pfft. {PAUSE 60}Consider it penance for you not\n"
			"testing this thing properly.\l"
			"{EMOJI_BIGWHEEL}Sticks out her tongue playfully{EMOJI_BIGWHEEL}")
	speakername (CommonText_Sakura)
	msgbox ("If only we were back in high school,\n"
			"this gossip would be all the rage.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_Thinking)
	delay (60)
	speakername (CommonText_Redd)
	msgbox ("Well, I don't really wanna talk about\n"
			"anyone's love life.")
	speakername (CommonText_Jakson)
	msgbox ("We're not-{PAUSE 20}!")
	speakername (CommonText_Redd)
	msgbox ("If that's all, I think I do want to look\n"
			"around a bit more now that I have the\l"
			"chance.", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_REDD, Common_Movement_WalkDown2)
	waitmovement (0)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterDown)
	applymovement (MAUVECAMP_REDD, Common_Movement_WalkLeft9)
	waitmovement (0)
	playse (SE_PIN)
	applymovement (MAUVECAMP_SAKURA, Common_Movement_ExclamationMark)
	delay (60)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterUp)
	waitmovement (0)
	speakername (CommonText_Sakura)
	msgbox ("Oh, you're not getting ahead of me!", MSGBOX_AUTOCLOSE)
	applymovement (MAUVECAMP_SAKURA, Common_Movement_WalkFastDown)
	waitmovement (0)
	applymovement (LOCALID_PLAYER, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (MAUVECAMP_SAKURA, Common_Movement_WalkFastLeft4)
	waitmovement (0)
	applymovement (MAUVECAMP_BARON, Common_Movement_WalkInPlaceFasterLeft)
	applymovement (MAUVECAMP_SAKURA, Common_Movement_WalkFastDown2)
	waitmovement (0)
	applymovement (MAUVECAMP_SAKURA, Common_Movement_WalkFastLeft3)
	waitmovement (0)
	playse (SE_PIN)
	applymovement (MAUVECAMP_BARON, Common_Movement_ExclamationMark)
	delay (60)
	call (GetBaronsName)
	msgbox ("W-{PAUSE 30}wait! Me as well!", MSGBOX_AUTOCLOSE)
	applymovement (LOCALID_PLAYER, Common_Movement_WalkInPlaceFasterDown)
	applymovement (MAUVECAMP_JAKSON, Common_Movement_WalkInPlaceFasterUp)
	applymovement (MAUVECAMP_BARON, Common_Movement_WalkDown4)
	waitmovement (0)
