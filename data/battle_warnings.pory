script CheckBattleWarningLevel {
	setvar (VAR_TEMP_6, 1)
	checkwarningoption
	if (var(VAR_RESULT) == 0) {
		end
	}
	if (var(VAR_RESULT) == 1) {
		msgbox (ChallengingBattleImminent, MSGBOX_AUTOCLOSE)
		end
	}
	msgbox (ChallengingBattleImminent)
}

text ChallengingBattleImminent {
	"A challenging battle is imminent."
}

text OpponentVar {
	"The opponent is {STR_VAR_1}."
}


# Brendan/May battles

text OpponentBrendanMay {
	"The opponent is Brendan/May."
}

script BattleWarningRoute119Rival {
	if (var(VAR_ROUTE119_STATE) >= 1) {
		setvar (VAR_TEMP_6, 1)
		end
	}
	call (CheckBattleWarningLevel)
	msgbox (OpponentBrendanMay, MSGBOX_AUTOCLOSE)
}

script BattleWarningSkyPillarRival {
	if (flag(FLAG_DEFEATED_RIVAL_SKY_PILLAR)) {
		setvar (VAR_TEMP_6, 1)
		end
	}
	call (CheckBattleWarningLevel)
	msgbox (OpponentBrendanMay, MSGBOX_AUTOCLOSE)
}


# Wally battles

script BattleWarningPetalburgWally {
	if (var(VAR_PETALBURG_CITY_STATE) != 5) {
		setvar (VAR_TEMP_6, 1)
		end
	}
	call (CheckBattleWarningLevel)
	bufferstring (STR_VAR_1, CommonText_Wally)
	msgbox (OpponentVar, MSGBOX_AUTOCLOSE)
}

script BattleWarningVRWally {
	if (flag(FLAG_DEFEATED_WALLY_VICTORY_ROAD)) {
		setvar (VAR_TEMP_6, 1)
		end
	}
	call (CheckBattleWarningLevel)
	bufferstring (STR_VAR_1, CommonText_Wally)
	msgbox (OpponentVar, MSGBOX_AUTOCLOSE)
}


# Rival battles

text OpponentAllRivals {
	"The opponents will be all rivals in\n"
	"sequence.\p"
	"You will be healed between battles.\n"
	"Victories are saved if a battle is lost."
}

script BattleWarningPetalburgRival {
	if (var(VAR_EMERALBODY_RIVAL_STATE) != 1) {
		setvar (VAR_TEMP_6, 1)
		end
	}
	call (CheckBattleWarningLevel)
	msgbox (ChallengingBattleImminent, MSGBOX_AUTOCLOSE)
}

script BattleWarningPokemonLeagueRival {
	if (var(VAR_EMERALBODY_RIVAL_STATE) >= 25) {
		setvar (VAR_TEMP_6, 1)
		end
	}
	call (CheckBattleWarningLevel)
	switch (var(VAR_EMERALBODY_RIVAL)) {
		case 0:
			bufferstring (STR_VAR_1, CommonText_Baron)
		case 1:
			bufferstring (STR_VAR_1, CommonText_Harper)
		case 2:
			bufferstring (STR_VAR_1, CommonText_Jakson)
		case 3:
			bufferstring (STR_VAR_1, CommonText_Redd)
		case 4:
			bufferstring (STR_VAR_1, CommonText_Sakura)
		case 5:
			msgbox (OpponentAllRivals, MSGBOX_AUTOCLOSE)
			releaseall
			end
	}
	msgbox (OpponentVar, MSGBOX_AUTOCLOSE)
	releaseall
}

